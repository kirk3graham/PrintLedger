# XRPL Node URLs
VITE_XRPL_TESTNET_URL=wss://s.altnet.rippletest.net:51233
VITE_XRPL_MAINNET_URL=wss://xrplcluster.com

# Platform wallet (brokered fee recipient) - optional
VITE_PLATFORM_WALLET_ADDRESS=

# IPFS/Arweave (client-side upload)
VITE_PINATA_API_KEY=
VITE_PINATA_SECRET_KEY=

# Platform fee (basis points, 50 = 0.5%, 200 = 2%)
VITE_PLATFORM_FEE_BPS=100
