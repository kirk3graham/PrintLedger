# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/printledger

# ─── XRPL Node ───────────────────────────────────────────────────────────────
XRPL_WS_URL=wss://xrplcluster.com

# ─── Pinata / IPFS ───────────────────────────────────────────────────────────
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3001

# ─── Indexer behaviour ────────────────────────────────────────────────────────
# Comma-separated list of issuer accounts to watch (leave empty to watch all NFTokenMint)
WATCH_ISSUERS=
# How often (in ms) to refresh sell-offer state for all models
OFFER_REFRESH_INTERVAL_MS=300000
# Max retries for IPFS metadata fetch
METADATA_MAX_RETRIES=3
# Delay (in ms) between retries
METADATA_RETRY_DELAY_MS=2000
